---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEOHead from '../components/SEOHead.astro';
import { site } from '../config/site';
import { buildWebSiteSchema } from '../lib/schema';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  publishedDate?: Date;
  updatedDate?: Date;
  keywords?: string[];
  schemas?: Record<string, unknown>[];
  noindex?: boolean;
  fullWidth?: boolean;
}

const {
  title,
  description,
  canonical,
  ogType = 'website',
  ogImage,
  publishedDate,
  updatedDate,
  keywords,
  schemas = [],
  noindex,
  fullWidth = false,
} = Astro.props;

const jsonLd = [buildWebSiteSchema(), ...schemas];
---

<!doctype html>
<html lang={site.lang}>
  <head>
    <SEOHead
      title={title}
      description={description}
      canonical={canonical}
      ogType={ogType}
      ogImage={ogImage}
      publishedDate={publishedDate}
      updatedDate={updatedDate}
      keywords={keywords}
      schemas={jsonLd}
      noindex={noindex}
    />
  </head>
  <body>
    <Header />
    <main id="main-content" class:list={[!fullWidth && 'container', 'page-main']}>
      <slot />
    </main>
    <Footer />
  </body>
</html>
