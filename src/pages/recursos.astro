---
import PillarLayout from '../layouts/PillarLayout.astro';
import { getArticlesByPillar, getArticleUrl } from '../lib/articles';

const pillar = 'recursos';
const articles = await getArticlesByPillar(pillar);

const title = 'Recursos y scripts para estudiantes';
const description =
  'Biblioteca directa de apuntes, scripts y ejemplos prácticos para alumnos que quieren repasar programación, SQL y bases de datos sin perder tiempo.';
const keywords = [
  'recursos programación',
  'scripts SQL',
  'apuntes programación',
  'biblioteca para estudiantes',
  'ejemplos SQL',
];

const breadcrumbs = [
  { label: 'Inicio', href: '/' },
  { label: 'Recursos', href: '/recursos' },
];
---

<PillarLayout
  title={title}
  description={description}
  canonical="/recursos"
  keywords={keywords}
  breadcrumbs={breadcrumbs}
>
  <div class="resources-page">
    <section class="resources-dashboard" aria-label="Resumen de recursos">
      <div class="resources-console" aria-hidden="true">
        <div class="resources-console-bar">
          <span></span>
          <span></span>
          <span></span>
          <strong>resources.json</strong>
        </div>
        <pre><code>&#123;
  "modo": "estudiar",
  "stack": ["SQL", "bases de datos"],
  "objetivo": "practicar sin perder tiempo"
&#125;</code></pre>
      </div>

      <ul class="resources-stats">
        <li>
          <strong>{articles.length}</strong>
          <span>recursos publicados</span>
        </li>
        <li>
          <strong>SQL</strong>
          <span>apuntes y ejemplos</span>
        </li>
        <li>
          <strong>DEV</strong>
          <span>material para practicar</span>
        </li>
      </ul>
    </section>

    <section class="pillar-topics resources-library" aria-labelledby="recursos-articles-title">
      <div class="resources-library-header">
        <span class="resources-kicker">Biblioteca</span>
        <h2 id="recursos-articles-title">Recursos listos para estudiar</h2>
        <p>Guías escritas, ejemplos y explicaciones pensadas para volver cuando estés practicando.</p>
      </div>

    {articles.length > 0 ? (
      <ul class="article-list resources-list">
        {articles.map((article) => (
          <li>
            <a class="resource-card" href={getArticleUrl(article)}>
              <span class="resource-card-meta">{article.data.pillar.toUpperCase()} · Recurso</span>
              <span class="related-title resource-card-title">{article.data.title}</span>
              <span class="related-description">{article.data.description}</span>
              <span class="resource-card-cta">Abrir recurso</span>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="resources-empty">Próximamente publicaremos scripts, apuntes y recursos para estudiar.</p>
    )}
    </section>
  </div>
</PillarLayout>
