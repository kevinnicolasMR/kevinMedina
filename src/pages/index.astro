---
import BaseLayout from '../layouts/BaseLayout.astro';
import DeveloperHero from '../components/DeveloperHero.astro';
import VideoPagesGrid from '../components/VideoPagesGrid.astro';
import { site } from '../config/site';
import { getPublishedArticles } from '../lib/articles';

const articles = await getPublishedArticles();
---

<BaseLayout
  title={site.title}
  description={site.description}
  canonical="/"
  keywords={['programación', 'SQL', 'tutoriales', 'YouTube', 'Kevin Medina']}
>
  <DeveloperHero />
  <VideoPagesGrid articles={articles} />
</BaseLayout>
