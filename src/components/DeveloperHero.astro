---
import { site } from '../config/site';

const { developer } = site;
---

<section class="developer-hero" aria-labelledby="developer-hero-title">
  <div class="developer-hero-media">
    <img
      src={developer.image}
      alt={developer.imageAlt}
      width="400"
      height="400"
      loading="eager"
      decoding="async"
      class="developer-hero-image"
    />
  </div>

  <div class="developer-hero-content">
    <p class="developer-hero-role">{developer.role}</p>
    <h1 id="developer-hero-title">{developer.headline}</h1>
    {developer.bio.map((paragraph) => (
      <p class="developer-hero-text">{paragraph}</p>
    ))}
    <p class="developer-hero-actions">
      <a class="button" href={developer.ctaHref}>
        {developer.ctaLabel}
      </a>
      <a
        class="developer-hero-link"
        href={site.youtube.channelUrl}
        rel="noopener noreferrer"
        target="_blank"
      >
        Canal de YouTube
      </a>
    </p>
  </div>
</section>
