---
import type { ArticleEntry } from '../../lib/articles';
import { getArticleThumbnail, getArticleUrl } from '../../lib/articles';
import { home } from '../../config/home';
import SectionHeading from './SectionHeading.astro';

interface Props {
  articles: ArticleEntry[];
}

const { articles } = Astro.props;
const { videos } = home;
const featured = articles.filter((article) => Boolean(article.data.youtubeVideoId));
---

<section class="home-section featured-videos" id={videos.id} aria-labelledby="videos-title">
  <div class="container">
    <SectionHeading
      title={videos.title}
      description={videos.description}
      id="videos-title"
      centered
    />

    {featured.length > 0 ? (
      <div class="featured-videos-carousel">
        <button
          type="button"
          class="carousel-btn carousel-btn--prev"
          data-carousel-prev
          aria-label="Ver videos anteriores"
        >
          <span aria-hidden="true">‹</span>
        </button>

        <ul class="featured-videos-track" data-carousel-track>
          {featured.map((article) => (
            <li>
              <a class="featured-video-card" href={getArticleUrl(article)}>
                <span class="featured-video-thumb">
                  <img
                    src={getArticleThumbnail(article)}
                    alt={`Miniatura: ${article.data.title}`}
                    width="480"
                    height="270"
                    loading="lazy"
                    decoding="async"
                  />
                  <span class="featured-video-play" aria-hidden="true">▶</span>
                </span>
                <span class="featured-video-body">
                  <span class="featured-video-title">{article.data.title}</span>
                  <span class="featured-video-meta">
                    {article.data.pillar.toUpperCase()} · Guía escrita
                  </span>
                </span>
              </a>
            </li>
          ))}
        </ul>

        <button
          type="button"
          class="carousel-btn carousel-btn--next"
          data-carousel-next
          aria-label="Ver más videos"
        >
          <span aria-hidden="true">›</span>
        </button>
      </div>
    ) : (
      <p class="home-empty">Próximamente publicaré más tutoriales en video.</p>
    )}
  </div>
</section>

<script>
  function initVideoCarousel() {
    const carousels = document.querySelectorAll<HTMLElement>(
      '.featured-videos-carousel',
    );

    carousels.forEach((carousel) => {
      const track = carousel.querySelector<HTMLElement>(
        '[data-carousel-track]',
      );
      const prev = carousel.querySelector<HTMLButtonElement>(
        '[data-carousel-prev]',
      );
      const next = carousel.querySelector<HTMLButtonElement>(
        '[data-carousel-next]',
      );
      if (!track || !prev || !next) return;

      function scrollByCard(direction: number) {
        if (!track) return;
        const card = track.querySelector<HTMLElement>('li');
        const style = getComputedStyle(track);
        const gap = parseFloat(style.columnGap || style.gap || '0') || 0;
        const amount = card
          ? card.getBoundingClientRect().width + gap
          : track.clientWidth;
        track.scrollBy({ left: direction * amount, behavior: 'smooth' });
      }

      function updateButtons() {
        if (!track || !prev || !next) return;
        const maxScroll = track.scrollWidth - track.clientWidth - 1;
        prev.disabled = track.scrollLeft <= 0;
        next.disabled = track.scrollLeft >= maxScroll;
      }

      prev.addEventListener('click', () => scrollByCard(-1));
      next.addEventListener('click', () => scrollByCard(1));
      track.addEventListener('scroll', updateButtons, { passive: true });
      window.addEventListener('resize', updateButtons);
      updateButtons();
    });
  }

  initVideoCarousel();
  document.addEventListener('astro:page-load', initVideoCarousel);
</script>
