---
import type { ArticleEntry } from '../lib/articles';
import { getArticleThumbnail, getArticleUrl } from '../lib/articles';

interface Props {
  articles: ArticleEntry[];
  title?: string;
  description?: string;
  id?: string;
}

const {
  articles,
  title = 'Tutoriales en video',
  description = 'Cada tarjeta lleva a la guía escrita del tutorial, con pasos detallados y recursos complementarios.',
  id = 'tutoriales',
} = Astro.props;
---

<section class="video-pages-grid" id={id} aria-labelledby={`${id}-title`}>
  <header class="video-pages-grid-header">
    <h2 id={`${id}-title`}>{title}</h2>
    <p>{description}</p>
  </header>

  {articles.length > 0 ? (
    <ul class="video-pages-list">
      {articles.map((article) => (
        <li>
          <a class="video-page-card" href={getArticleUrl(article)}>
            <img
              src={getArticleThumbnail(article)}
              alt=""
              width="480"
              height="270"
              loading="lazy"
              decoding="async"
            />
            <span class="video-page-card-body">
              <span class="video-page-card-pillar">{article.data.pillar.toUpperCase()}</span>
              <span class="video-page-card-title">{article.data.title}</span>
              <span class="video-page-card-description">{article.data.description}</span>
            </span>
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <p class="video-pages-empty">
      Próximamente publicaré más tutoriales en video.
    </p>
  )}
</section>
